# =============================================================================
# UnderFireAI — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development, or paste each value into
# the Vercel Environment Variables panel for production.
#
# Values are intentionally left blank. The runtime throws early with a clear
# error when a required variable is missing, so an unfilled value will not
# silently break in production — it will fail loudly on first request.
#
# `NEXT_PUBLIC_*` variables are bundled into the client. Do not put anything
# secret behind that prefix.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# App URL (required)
# ─────────────────────────────────────────────────────────────────────────────
# Public origin of the deployed app. Used by:
#   - Stripe checkout/return URLs
#   - OpenRouter HTTP-Referer header
#   - sitemap.ts and robots.ts base URL
#   - Auth callback redirect resolution
# Format: full origin with scheme, no trailing slash.
#   Local:      http://localhost:3000
#   Production: https://www.underfireai.com
NEXT_PUBLIC_APP_URL=


# ─────────────────────────────────────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────────────────────────────────────
# Project URL and anon key are public (client-side). Service-role key is
# server-only — it bypasses RLS, never expose it to the browser.
# Get all three from: Supabase Dashboard → Project Settings → API
# Project ID for UnderFireAI: nodkmtwchiivlwjktzis
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter (required)
# ─────────────────────────────────────────────────────────────────────────────
# Powers all AI calls — interview chat (DeepSeek V3), per-message analysis
# (Mistral Small), coaching notes, JD parsing, and resume vulnerability scan.
# Get it from: https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Stripe (required)
# ─────────────────────────────────────────────────────────────────────────────
# Secret key and webhook signing secret.
#   Get the secret key from: Stripe Dashboard → Developers → API keys
#   Get the webhook secret from: Stripe Dashboard → Developers → Webhooks
#     → select the underfireai endpoint → "Signing secret"
# Format: sk_live_... (production) or sk_test_... (test mode)
#         whsec_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — one per credit pack. Created in:
#   Stripe Dashboard → Product Catalog → each product → Pricing → API ID
# Format: price_...
#   STARTER   = Starter Pack    (6 interviews, $25)
#   PRO_PACK  = Pro Pack        (11 interviews, $35)
#   REFILL    = Refill Pack     (+5 interviews, $10 — requires prior pack)
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PACK_PRICE_ID=
STRIPE_REFILL_PRICE_ID=


# ─────────────────────────────────────────────────────────────────────────────
# OpenAI TTS (required for voice mode)
# ─────────────────────────────────────────────────────────────────────────────
# Powers the interviewer voice output via OpenAI's TTS API. Without this, the
# /tts route will throw on first call and voice mode will be unusable; text
# mode continues to work.
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Judge0 via RapidAPI (required for coding interviews)
# ─────────────────────────────────────────────────────────────────────────────
# Sandboxed code execution for the coding interview track. Without these, the
# Run Code / Submit buttons in coding sessions will fail; non-coding interview
# types continue to work.
# Sign up at: https://rapidapi.com/judge0-official/api/judge0-ce
# Format:
#   HOST = judge0-ce.p.rapidapi.com
#   KEY  = your RapidAPI key (long alphanumeric)
JUDGE0_API_HOST=
JUDGE0_API_KEY=


# =============================================================================
# OPTIONAL — leave unset to use safe defaults
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting via Upstash Redis (optional, fail-open)
# ─────────────────────────────────────────────────────────────────────────────
# The rate-limit subsystem is gated behind RATE_LIMIT_ENABLED. With the flag
# unset (or set to anything other than the exact string "true"), every call
# to checkRateLimit() returns { allowed: true } with no Redis lookup — the
# app works normally without these variables.
#
# To activate: provision an Upstash Redis database, fill in the two values
# below, then set RATE_LIMIT_ENABLED=true.
#   Sign up at: https://console.upstash.com/
#   Copy URL + token from: your Redis database → "REST API" section
#
# Behaviour when enabled:
#   - Per-user limits on TTS, resume upload, JD parse, coaching, analysis
#   - Per-session limits on chat turns and Judge0 code execution
#   - Fail-open: if Upstash is unreachable, requests are allowed through
RATE_LIMIT_ENABLED=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=


# ─────────────────────────────────────────────────────────────────────────────
# 3D HUD feature flag (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Set to the exact string "true" to render the experimental 3D interviewer
# HUD instead of the default 2D InterviewChat layout. Read at runtime so it
# can be flipped on Vercel without a redeploy.
NEXT_PUBLIC_ENABLE_3D_HUD=
