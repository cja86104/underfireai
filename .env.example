# UnderFireAI Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE
# ===========================================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# AI / LLM
# ===========================================
# OpenRouter API key for AI model access
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI API key for Text-to-Speech (voice mode)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ===========================================
# STRIPE (Payments)
# ===========================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Webhook signing secret
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs for subscription tiers
# Create products/prices in Stripe Dashboard
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly_id

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_NAME=UnderFireAI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# IMAGE GENERATION (Segmind)
# ===========================================
# For generating interview scene images
# Get from https://www.segmind.com/
SEGMIND_API_KEY=your-segmind-key

# ===========================================
# CARTESIA (Text-to-Speech)
# ===========================================
# For interviewer voice mode (Pro/Premium only)
# Get from https://play.cartesia.ai/
CARTESIA_API_KEY=your-cartesia-api-key

# ===========================================
# DEVELOPMENT
# ===========================================
NODE_ENV=development
